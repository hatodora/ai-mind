rules_version = '2';

// ============================================================
// 思索 / Mindmap — Firestore セキュリティルール (SEC-01)
// 方針:
//  - デフォルト全拒否。許可は明示的に最小限のみ
//  - メール確認済み（2段階確認完了）ユーザーのみ書き込み可
//  - 開発者/運用者は Admin カスタムクレーム（admin: true）で別権限
//    （設定は Admin SDK: setCustomUserClaims で行う。クライアントからは不可）
//  - 将来の共有機能（Phase 4）: visibility + sharedWith{uid: role} で
//    viewer / editor を細かく制御できる設計
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- 共通ヘルパー ----------
    function isSignedIn() {
      return request.auth != null;
    }
    // メール確認済み = 2段階確認完了ユーザーのみ実質的な操作を許可
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    // 開発・運用ユーザー（カスタムクレーム）。一般フローとは別枠
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ---------- users/{uid}: プロフィール（NF-06） ----------
    match /users/{uid} {
      function isSelf() {
        return isVerified() && request.auth.uid == uid;
      }
      // フィールド単位の検証。型・桁・不変条件をすべて強制する
      function validUser() {
        let d = request.resource.data;
        return d.keys().hasOnly(
            ['uid', 'email', 'displayName', 'age', 'birthDate', 'birthDateEdits',
             'photoURL', 'assistLevel', 'personality', 'showNameInCommunity',
             'termsVersion', 'termsAcceptedAt',
             'role', 'createdAt', 'updatedAt'])
          && d.uid == uid
          // email は認証トークンと一致するもののみ（他人のアドレスを保存できない）
          && d.email is string && d.email.size() <= 320
          && d.email == request.auth.token.email
          && d.displayName is string
          && d.displayName.size() >= 1 && d.displayName.size() <= 30
          && d.age is int && d.age >= 5 && d.age <= 120
          && (!('birthDate' in d)
              || (d.birthDate is string && d.birthDate.size() == 10))
          // 誕生日の自己変更回数（SEC-01 F-1）。0〜2回まで、超過は管理者対応
          && (!('birthDateEdits' in d)
              || (d.birthDateEdits is int
                  && d.birthDateEdits >= 0 && d.birthDateEdits <= 2))
          && (d.photoURL == null
              || (d.photoURL is string && d.photoURL.size() <= 2048))
          && (!('assistLevel' in d)
              || d.assistLevel in ['level1', 'level2', 'level3', 'off'])
          && (!('personality' in d)
              || d.personality in ['advisor', 'boss', 'analyst'])
          && (!('showNameInCommunity' in d) || d.showNameInCommunity is bool)
          // 合意した利用規約バージョン（REL-03）。1 以上の整数のみ
          && (!('termsVersion' in d)
              || (d.termsVersion is int && d.termsVersion >= 1))
          && (!('termsAcceptedAt' in d) || d.termsAcceptedAt is number)
          && d.createdAt is number && d.updatedAt is number;
      }
      // 一般ユーザーは自分を admin に昇格できない
      function roleUnchanged() {
        return request.resource.data.role == 'user'
          || (resource != null && request.resource.data.role == resource.data.role);
      }
      // 誕生日は一度設定したら本人は2回までしか変更できない（SEC-01 F-1）。
      // クリア→再設定で回数をリセットできないよう、既存の誕生日を消すことも禁止する。
      // 3回目以降・削除からの復元は isAdmin() 経由（管理者への問い合わせ対応）のみ許可。
      function birthDateEditsOk() {
        let d = request.resource.data;
        let hadBirthDate = resource != null && ('birthDate' in resource.data);
        let oldBirthDate = hadBirthDate ? resource.data.birthDate : null;
        let newBirthDate = ('birthDate' in d) ? d.birthDate : null;
        let oldEdits = (resource != null && 'birthDateEdits' in resource.data)
          ? resource.data.birthDateEdits : 0;
        let newEdits = ('birthDateEdits' in d) ? d.birthDateEdits : 0;
        let changed = hadBirthDate && newBirthDate != null
          && newBirthDate != oldBirthDate;
        return (!hadBirthDate || newBirthDate != null)
          && (changed
              ? (oldEdits < 2 && newEdits == oldEdits + 1)
              : newEdits == oldEdits);
      }

      allow get: if isSelf() || isAdmin();
      allow list: if isAdmin();
      allow create: if (isSelf() && validUser()
                        && request.resource.data.role == 'user'
                        && birthDateEditsOk())
                    || isAdmin();
      allow update: if (isSelf() && validUser() && roleUnchanged()
                        && birthDateEditsOk())
                    || isAdmin();
      allow delete: if isSelf() || isAdmin();

      // レートリミット等の内部データは Admin SDK（Cloud Functions）専用
      match /private/{docId} {
        allow read, write: if false;
      }

      // ---------- ブックマーク（NF-01b）: 本人専用・全年齢 ----------
      match /bookmarks/{postId} {
        function validBookmark() {
          let d = request.resource.data;
          return d.keys().hasOnly(
              ['postId', 'theme', 'rootLabel', 'title', 'nodeCount',
               'authorName', 'postCreatedAt', 'createdAt'])
            && d.postId == postId
            && d.theme is string && d.theme.size() <= 200
            && d.rootLabel is string && d.rootLabel.size() <= 300
            && (!('title' in d)
                || (d.title is string && d.title.size() <= 100))
            && d.nodeCount is int && d.nodeCount >= 0
            && (d.authorName == null
                || (d.authorName is string && d.authorName.size() <= 30))
            && d.postCreatedAt is number
            && d.createdAt is number;
        }
        allow read, delete: if isSelf() || isAdmin();
        allow create, update: if isSelf() && validBookmark();
      }
    }

    // ---------- maps/{mapId}: マインドマップ ----------
    match /maps/{mapId} {
      function isOwner() {
        return isVerified() && resource.data.ownerId == request.auth.uid;
      }
      // 共有ロール取得（Phase 4 の共有機能に対応済み）
      function shareRole() {
        return resource.data.sharedWith[request.auth.uid];
      }
      function canRead() {
        return isAdmin()
          || isOwner()
          || resource.data.visibility == 'public'
          || (isVerified()
              && resource.data.visibility != 'private'
              && request.auth.uid in resource.data.sharedWith);
      }
      function canEdit() {
        return isAdmin()
          || isOwner()
          || (isVerified()
              && resource.data.visibility != 'private'
              && shareRole() == 'editor');
      }
      function validMap() {
        let d = request.resource.data;
        return d.keys().hasOnly(
            ['id', 'theme', 'nodes', 'edges', 'currentTurn', 'turnCount',
             'aiGauge', 'assistLevel', 'aiRequestCount', 'completed',
             'completedAt', 'createdAt', 'updatedAt', 'ownerId',
             'visibility', 'sharedWith', 'collaboratorNames'])
          && d.id == mapId
          && d.theme is string && d.theme.size() >= 1 && d.theme.size() <= 200
          && d.nodes is list && d.nodes.size() <= 500
          && d.edges is list && d.edges.size() <= 1000
          && d.currentTurn in ['user', 'ai']
          && d.turnCount is int && d.turnCount >= 0
          && d.aiGauge is number
          && (!('assistLevel' in d)
              || d.assistLevel in ['level1', 'level2', 'level3', 'off'])
          && (!('aiRequestCount' in d)
              || (d.aiRequestCount is int && d.aiRequestCount >= 0))
          && (!('completed' in d) || d.completed is bool)
          && (!('completedAt' in d) || d.completedAt is number)
          && d.ownerId is string
          && d.visibility in ['private', 'shared', 'public']
          && d.sharedWith is map
          && (!('collaboratorNames' in d) || d.collaboratorNames is map)
          && d.createdAt is number && d.updatedAt is number;
      }
      // 共有相手（editor）は内容を編集できるが、
      // 所有者・公開範囲・共有設定・参加者名は所有者にしか変更させない
      function aclUnchanged() {
        return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['ownerId', 'visibility', 'sharedWith', 'collaboratorNames']);
      }

      allow read: if canRead();
      allow create: if isAdmin()
        || (isVerified()
            && request.resource.data.ownerId == request.auth.uid
            && validMap());
      allow update: if isAdmin()
        || (canEdit()
            && validMap()
            && (isOwner() || aclUnchanged()));
      allow delete: if isAdmin() || isOwner();
    }

    // ---------- posts: コミュニティ投稿（NF-01b） ----------
    // 閲覧は全年齢（ログイン＋メール確認必須）。投稿・コメントは15歳以上。
    // 投稿者名はプロフィールの表示名と一致するか匿名（null）のみ＝なりすまし不可。
    match /posts/{postId} {
      function myProfile() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      }
      // 15歳以上のみ投稿・コメントできる（クライアントUIに加えて二重に強制）
      function canPublish() {
        return isVerified() && myProfile().age >= 15;
      }
      function validAuthorName(name) {
        return name == null
          || (name is string && name.size() <= 30
              && name == myProfile().displayName);
      }
      function validPost() {
        let d = request.resource.data;
        return d.keys().hasOnly(
            ['id', 'authorUid', 'authorName', 'theme', 'rootLabel',
             'title', 'body', 'nodes', 'edges', 'commentCount', 'createdAt'])
          && d.id == postId
          && d.authorUid == request.auth.uid
          && validAuthorName(d.authorName)
          && d.theme is string && d.theme.size() >= 1 && d.theme.size() <= 200
          && d.rootLabel is string
          && d.rootLabel.size() >= 1 && d.rootLabel.size() <= 300
          && (!('title' in d)
              || (d.title is string && d.title.size() >= 1 && d.title.size() <= 100))
          && (!('body' in d)
              || (d.body is string && d.body.size() >= 1 && d.body.size() <= 1000))
          && d.nodes is list && d.nodes.size() >= 1 && d.nodes.size() <= 200
          && d.edges is list && d.edges.size() <= 400
          && d.commentCount == 0
          && d.createdAt is number;
      }
      // 投稿本体の更新は commentCount の ±1 のみ（コメント作成/削除の batch 用）。
      // Cloud Functions を使わずにカウントを安全に保つ
      function onlyCommentCountDelta() {
        let d = request.resource.data;
        return d.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
          && (d.commentCount == resource.data.commentCount + 1
              || d.commentCount == resource.data.commentCount - 1)
          && d.commentCount >= 0;
      }

      allow read: if isVerified() || isAdmin();
      allow create: if (canPublish() && validPost()) || isAdmin();
      allow update: if (canPublish() && onlyCommentCountDelta()) || isAdmin();
      allow delete: if isAdmin()
        || (isVerified() && resource.data.authorUid == request.auth.uid);

      // ---------- コメント。既定は匿名（authorName = null） ----------
      match /comments/{commentId} {
        function validComment() {
          let d = request.resource.data;
          return d.keys().hasOnly(
              ['id', 'authorUid', 'authorName', 'text', 'createdAt'])
            && d.id == commentId
            && d.authorUid == request.auth.uid
            && validAuthorName(d.authorName)
            && d.text is string && d.text.size() >= 1 && d.text.size() <= 500
            && d.createdAt is number;
        }
        allow read: if isVerified() || isAdmin();
        allow create: if (canPublish() && validComment()) || isAdmin();
        // 編集は不可。削除はコメント本人か、親投稿の作者（投稿の連鎖削除
        // ＝孤児コメント防止のため。SEC-01 F-3）
        allow update: if isAdmin();
        allow delete: if isAdmin()
          || (isVerified()
              && (resource.data.authorUid == request.auth.uid
                  || get(/databases/$(database)/documents/posts/$(postId))
                       .data.authorUid == request.auth.uid));
      }
    }

    // ---------- inquiries: お問い合わせ（REL-04） ----------
    // 作成はログインユーザーのみ。閲覧・更新・削除は管理者専用。
    // 「メール未確認」でも送信できるようにするため isSignedIn() を使う
    // （アカウント削除・誕生日変更依頼など、規約合意前のケースも受け付ける）
    match /inquiries/{id} {
      function validInquiry() {
        let d = request.resource.data;
        return d.keys().hasOnly(
            ['id', 'category', 'email', 'message', 'submittedByUid',
             'status', 'createdAt', 'updatedAt'])
          && d.id == id
          && d.category in ['bug', 'deletion', 'birthdate', 'account', 'other']
          && d.email is string && d.email.size() >= 3 && d.email.size() <= 320
          && d.message is string
          && d.message.size() >= 1 && d.message.size() <= 4000
          && d.submittedByUid == request.auth.uid
          && d.status == 'new'
          && d.createdAt is number
          && d.updatedAt is number;
      }
      allow get, list, update, delete: if isAdmin();
      allow create: if isSignedIn() && validInquiry();
    }

    // ---------- invites: 共同編集の招待（NF-01a・Cloud Functions 専用） ----------
    // token が秘密そのものなので、クライアントからの読み書きは一切許可しない
    match /invites/{token} {
      allow read, write: if false;
    }

    // ---------- aiCache: AI応答キャッシュ（Cloud Functions 専用） ----------
    match /aiCache/{key} {
      allow read, write: if false;
    }

    // ---------- 上記以外はすべて拒否 ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
